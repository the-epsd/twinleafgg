{
  "name": "ptcg-play-svelte",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0 <25"
  },
  "scripts": {
    "dev": "npm run dev:engine & npm run dev:web",
    "dev:web": "vite --host 0.0.0.0 --port 5174 --strictPort",
    "dev:engine": "tsx src/engine/server.ts",
    "build": "tsc -p tsconfig.json && vite build",
    "test": "vitest run",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "ptcg-server": "file:../ptcg-server",
    "socket.io-client": "^4.8.3",
    "svelte": "^5.45.6",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vitest": "^4.0.15"
  }
}
